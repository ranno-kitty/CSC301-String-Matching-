algorithm RabinKarpSearch(P, T, hashT, hashP):
    // INPUT
    // P = The pattern to look for
    // T = The text to look in
    // hashT, hashP = Hash structures for strings T, P
    // OUTPUT
    // Returns the number of occurrences of P in T
    answer <- 0
    Time Complexity: O(1)
    n <- length(T)
    Time Complexity: O(1)
    k <- length(P)
    Time Complexity: O(1)
    for i <- 0 to n - k:
     Time Complexity: O(n)
        textHash <- hashT.getHash(i, i + k - 1)
       Time Complexity: O(1)
        patternHash <- hashP.getHash(0, k - 1)
       Time Complexity: O(1)
        if textHash = patternHash:
        Time Complexity: O(1)
            valid <- true
         Time Complexity: O(1)
            for j <- 0 to k - 1:
          Time Complexity: O(k)
                if T[i + j] != P[j]:
           Time Complexity: O(1)
                    valid <- false
              Time Complexity: O(1)
                    break
      Time Complexity: O(1)
            if valid = true:
      Time Complexity: O(1)
                answer <- answer + 1
     Time Complexity: O(1)
    return answer
    Time Complexity: O(1)
